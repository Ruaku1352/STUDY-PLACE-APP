// Prisma schema — 勉強スケジュール管理アプリ
// 詳細は SPEC.md / CLAUDE.md を参照。全テーブルに userId を持たせ、userId でスコープする。

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    String @id @default(cuid())
  email String @unique
  name  String?

  /** Googleカレンダー連携用（Auth.jsのJWTセッションではなくDBに永続化し、サーバーアクションから利用する） */
  googleRefreshToken         String?
  googleAccessToken          String?
  googleAccessTokenExpiresAt DateTime?

  subjects     Subject[]
  weeklyPlans  WeeklyPlan[]
  locations    Location[]
  fixedEvents  FixedEvent[]
  settings     Settings?
  travelCaches TravelCache[]
  scheduleBlocks ScheduleBlock[]
  dayStates   DayState[]
  books        Book[]
  readingLogs  ReadingLog[]
  streak       Streak?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubjectTimeSlot {
  morning
  anytime
}

model Subject {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  weeklyQuotaMin Int
  timeSlot       SubjectTimeSlot @default(anytime)

  scheduleBlocks ScheduleBlock[]
  books          Book[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model WeeklyPlan {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate DateTime
  // 優先順位: subjectId の配列 (JSON)
  priorities    Json
  // 週次AIノルマ提案のキャッシュ（WeeklyProposal型）。週ごとに1回だけ生成する。
  aiProposalJson Json?
  aiProposalAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@unique([userId, weekStartDate])
}

enum LocationKind {
  library
  cafe
  other
}

model Location {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  address         String
  placeId         String?
  kind            LocationKind
  maxStayMin      Int?
  openingHoursJson Json?
  openingHoursFetchedAt DateTime?
  manualHoursJson  Json?
  /** Routes API・キャッシュとも失敗した場合の手動フォールバック（home等からの移動分数） */
  manualTravelMin Int?

  fixedEvents    FixedEvent[]
  scheduleBlocks ScheduleBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum FixedEventKind {
  school
  work
  other
}

model FixedEvent {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  startsAt   DateTime
  endsAt     DateTime
  locationId String?
  location   Location?      @relation(fields: [locationId], references: [id])
  kind       FixedEventKind

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Settings {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAddress  String
  /** 天気予報取得(Open-Meteo)用の自宅座標。未設定なら天気機能はスキップされる。 */
  homeLat      Float?
  homeLng      Float?
  wakeWeekday  String
  wakeWeekend  String
  morningEnd   String   @default("12:00")
  outsideEnd   String   @default("21:00")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TravelCache {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "home" または placeId
  fromKey   String
  toKey     String
  minutes   Int
  fetchedAt DateTime @default(now())

  @@index([userId])
  @@unique([userId, fromKey, toKey])
}

enum ScheduleBlockType {
  study
  move
  break
  lunch
  event
}

enum ScheduleBlockStatus {
  planned
  done
  partial
  skipped
}

model ScheduleBlock {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  type        ScheduleBlockType
  startsAt    DateTime
  endsAt      DateTime
  subjectId   String?
  subject     Subject?            @relation(fields: [subjectId], references: [id])
  locationId  String?
  location    Location?           @relation(fields: [locationId], references: [id])
  status      ScheduleBlockStatus @default(planned)
  actualMin   Int?
  gcalEventId String?

  readingLogs ReadingLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, date])
}

model DayState {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  revealedAt  DateTime?
  rerollUsed  Boolean   @default(false)
  gaveUp      Boolean   @default(false)
  /** 開封時に生成する「本日の任務」風の演出テキスト。失敗時は固定文にフォールバックするためnull許容。 */
  missionText String?
  /** 開封時に取得した当日の1時間ごと天気予報(HourlyWeatherPoint[])。同日の再取得はしない（リロール時も再利用）。 */
  weatherJson       Json?
  weatherFetchedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@unique([userId, date])
}

model Book {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId     String
  subject       Subject   @relation(fields: [subjectId], references: [id])
  title         String
  publisher     String?
  totalPages    Int?
  /** base64 data URL（Blobストレージ未導入のためDBに直接保存） */
  coverImageUrl String?
  completedAt   DateTime?

  readingLogs ReadingLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ReadingLog {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId          String
  book            Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  scheduleBlockId String?
  scheduleBlock   ScheduleBlock? @relation(fields: [scheduleBlockId], references: [id])
  fromPage        Int
  toPage          Int
  date            DateTime

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([bookId])
}

model Streak {
  userId            String    @id
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentCount      Int       @default(0)
  longestCount      Int       @default(0)
  lastQualifiedDate DateTime?
  freezeUsedInWeek  Boolean   @default(false)

  updatedAt DateTime @updatedAt
}
